PACKAGE_NAME="ntfsplus"
PACKAGE_VERSION="@VERSION@"
BUILT_MODULE_NAME[0]="ntfsplus"
DEST_MODULE_LOCATION[0]="/kernel/fs/ntfsplus"
AUTOINSTALL="yes"
MAKE[0]="make default KDIR=/lib/modules/\${kernelver}/build LLVM=\$(grep -q 'CONFIG_CC_IS_CLANG=y' /lib/modules/\${kernelver}/build/.config && echo 1 || echo 0)"
CLEAN="make clean KDIR=/lib/modules/\${kernelver}/build"
